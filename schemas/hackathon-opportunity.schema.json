{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-team-os.local/schemas/hackathon-opportunity.schema.json",
  "title": "Agent Team OS Hackathon Opportunity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "source",
    "official_url",
    "organizer",
    "status",
    "discovered_at",
    "verified_at",
    "registration_deadline_utc",
    "submission_deadline_utc",
    "mode",
    "location",
    "languages",
    "eligibility",
    "team_size",
    "tracks",
    "required_technology",
    "allowed_preexisting_work",
    "deliverables",
    "ip_and_license_summary",
    "prize_and_network_value",
    "estimated_cost",
    "estimated_team_hours",
    "fit_assets",
    "hard_filter",
    "score",
    "confidence",
    "evidence",
    "human_gates"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "official_url": { "type": "string", "format": "uri" },
    "organizer": { "type": "string", "minLength": 1 },
    "status": {
      "enum": ["discovered", "verified", "shortlisted", "approved", "rejected", "active", "submitted", "closed"]
    },
    "discovered_at": { "type": "string", "format": "date-time" },
    "verified_at": {
      "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }]
    },
    "registration_deadline_utc": {
      "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }]
    },
    "submission_deadline_utc": {
      "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }]
    },
    "mode": {
      "oneOf": [{ "enum": ["online", "in_person", "hybrid"] }, { "type": "null" }]
    },
    "location": { "type": ["string", "null"] },
    "languages": { "$ref": "#/$defs/stringArray" },
    "eligibility": { "$ref": "#/$defs/stringArray" },
    "team_size": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["min", "max"],
          "properties": {
            "min": { "type": "integer", "minimum": 1 },
            "max": { "type": "integer", "minimum": 1 }
          }
        },
        { "type": "null" }
      ]
    },
    "tracks": { "$ref": "#/$defs/stringArray" },
    "required_technology": { "$ref": "#/$defs/stringArray" },
    "allowed_preexisting_work": { "enum": ["yes", "no", "partial", "unknown"] },
    "deliverables": { "$ref": "#/$defs/stringArray" },
    "ip_and_license_summary": { "type": "string" },
    "prize_and_network_value": { "type": "string" },
    "estimated_cost": { "type": ["number", "null"], "minimum": 0 },
    "estimated_team_hours": { "type": ["number", "null"], "minimum": 0 },
    "fit_assets": { "$ref": "#/$defs/stringArray" },
    "hard_filter": { "enum": ["pass", "fail", "needs_review"] },
    "score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "confidence": { "enum": ["low", "medium", "high"] },
    "evidence": { "$ref": "#/$defs/nonEmptyStringArray" },
    "human_gates": { "$ref": "#/$defs/stringArray" }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
